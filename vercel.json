{
  "version": 2,
  "installCommand": "cd apps/server && npm install",
  "buildCommand": "cd apps/server && npm run build",
  "outputDirectory": "public",
  "functions": {
    "apps/server/api/index.ts": {
      "includeFiles": "apps/server/dist/**,apps/server/GBA_Roms_Names.json,apps/server/GBA_Roms_Genres.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/server/api/index.ts"
    },
    {
      "source": "/Images/(.*)",
      "destination": "/apps/server/Images/$1"
    }
  ]
}
